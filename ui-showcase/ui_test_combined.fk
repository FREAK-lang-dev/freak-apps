-- Combined freak-ui build
-- FREAK Standard Library: std::ui
-- Layer 1 of freak-ui: Window management, events, and raw drawing
--
-- This is the "floor" — just enough to open a window, get input,
-- and draw pixels/text. No widgets, no layout, no retained state.
-- freak-ui (Hangar package) builds on top of this.

-- ================================================================
--  Core types
-- ================================================================

shape WindowConfig {
    title:     word
    width:     int
    height:    int
    resizable: bool
    vsync:     bool
}

shape Vec2 {
    x: num
    y: num
}

shape Rect {
    x: num
    y: num
    w: num
    h: num
}

impl Rect {
    task contains(self, px: num, py: num) -> bool {
        give back px >= self.x and px < self.x + self.w and py >= self.y and py < self.y + self.h
    }
}

shape Color {
    r: int
    g: int
    b: int
    a: int
}

impl Color {
    task rgb(r: int, g: int, b: int) -> Color {
        give back Color { r: r, g: g, b: b, a: 255 }
    }

    task rgba(r: int, g: int, b: int, a: int) -> Color {
        give back Color { r: r, g: g, b: b, a: a }
    }

    -- Named colors
    task red() -> Color { give back Color::rgb(255, 45, 45) }
    task green() -> Color { give back Color::rgb(45, 200, 45) }
    task blue() -> Color { give back Color::rgb(45, 120, 255) }
    task white() -> Color { give back Color::rgb(255, 255, 255) }
    task black() -> Color { give back Color::rgb(0, 0, 0) }
    task transparent() -> Color { give back Color::rgba(0, 0, 0, 0) }

    -- Theme colors
    task dark_bg() -> Color { give back Color::rgb(20, 20, 30) }
    task surface() -> Color { give back Color::rgb(35, 35, 50) }
    task accent() -> Color { give back Color::rgb(255, 45, 120) }
    task muted() -> Color { give back Color::rgb(128, 128, 160) }
}

shape Font {
    size: int
    bold: bool
    italic: bool
}

impl Font {
    task default() -> Font {
        give back Font { size: 14, bold: false, italic: false }
    }

    task heading() -> Font {
        give back Font { size: 24, bold: true, italic: false }
    }

    task mono() -> Font {
        give back Font { size: 13, bold: false, italic: false }
    }

    task display() -> Font {
        give back Font { size: 36, bold: true, italic: false }
    }
}

-- ================================================================
--  Events
-- ================================================================

-- Event kind constants (match C defines)
fixed pilot EVENT_NONE   = 0
fixed pilot EVENT_QUIT   = 1
fixed pilot EVENT_KEY    = 2
fixed pilot EVENT_CHAR   = 3
fixed pilot EVENT_MOUSE  = 4
fixed pilot EVENT_SCROLL = 5
fixed pilot EVENT_RESIZE = 6
fixed pilot EVENT_FOCUS  = 7

-- Key constants (match C defines)
fixed pilot KEY_A = 1
fixed pilot KEY_B = 2
fixed pilot KEY_C = 3
fixed pilot KEY_D = 4
fixed pilot KEY_E = 5
fixed pilot KEY_F = 6
fixed pilot KEY_G = 7
fixed pilot KEY_H = 8
fixed pilot KEY_I = 9
fixed pilot KEY_J = 10
fixed pilot KEY_K = 11
fixed pilot KEY_L = 12
fixed pilot KEY_M = 13
fixed pilot KEY_N = 14
fixed pilot KEY_O = 15
fixed pilot KEY_P = 16
fixed pilot KEY_Q = 17
fixed pilot KEY_R = 18
fixed pilot KEY_S = 19
fixed pilot KEY_T = 20
fixed pilot KEY_U = 21
fixed pilot KEY_V = 22
fixed pilot KEY_W = 23
fixed pilot KEY_X = 24
fixed pilot KEY_Y = 25
fixed pilot KEY_Z = 26
fixed pilot KEY_ENTER     = 37
fixed pilot KEY_ESCAPE    = 38
fixed pilot KEY_SPACE     = 39
fixed pilot KEY_TAB       = 40
fixed pilot KEY_BACKSPACE = 41
fixed pilot KEY_DELETE    = 42
fixed pilot KEY_UP        = 43
fixed pilot KEY_DOWN      = 44
fixed pilot KEY_LEFT      = 45
fixed pilot KEY_RIGHT     = 46

-- Mouse button constants
fixed pilot MOUSE_NONE   = 0
fixed pilot MOUSE_LEFT   = 1
fixed pilot MOUSE_RIGHT  = 2
fixed pilot MOUSE_MIDDLE = 3

-- Raw event shape (flat, easy FFI)
shape Event {
    kind:      int
    key:       int
    pressed:   int
    key_repeat:    int
    character: int
    mouse_x:   int
    mouse_y:   int
    button:    int
    scroll_dy: int
    width:     int
    height:    int
    gained:    int
}

impl Event {
    task is_quit(self) -> bool {
        give back self.kind == EVENT_QUIT
    }

    task is_key_down(self, k: int) -> bool {
        give back self.kind == EVENT_KEY and self.key == k and self.pressed == 1
    }

    task is_key_up(self, k: int) -> bool {
        give back self.kind == EVENT_KEY and self.key == k and self.pressed == 0
    }

    task is_mouse_down(self, btn: int) -> bool {
        give back self.kind == EVENT_MOUSE and self.button == btn and self.pressed == 1
    }

    task is_mouse_up(self, btn: int) -> bool {
        give back self.kind == EVENT_MOUSE and self.button == btn and self.pressed == 0
    }

    task is_click_in(self, rect: Rect) -> bool {
        give back self.kind == EVENT_MOUSE and self.button == MOUSE_LEFT and self.pressed == 1 and rect.contains(self.mouse_x, self.mouse_y)
    }
}

-- ================================================================
--  Window
-- ================================================================

-- Native C runtime interface (declared as extern, linked from win32_backend.c)
-- These are called through the compiler's extern mechanism:
--   freak_ui_create_window(title, width, height, resizable) -> handle
--   freak_ui_poll_events(handle) -> event_count (-1 = quit)
--   freak_ui_event_kind(index) -> kind
--   freak_ui_event_key(index) -> key
--   ... etc for each event field
--   freak_ui_begin_frame(handle)
--   freak_ui_end_frame(handle)
--   freak_ui_clear(handle, r, g, b, a)
--   freak_ui_fill_rect(handle, x, y, w, h, r, g, b, a)
--   freak_ui_stroke_rect(handle, x, y, w, h, r, g, b, a, thickness)
--   freak_ui_fill_circle(handle, cx, cy, radius, r, g, b, a)
--   freak_ui_draw_line(handle, x1, y1, x2, y2, r, g, b, a, thickness)
--   freak_ui_draw_text(handle, text, x, y, r, g, b, font_size, bold, italic) -> width
--   freak_ui_measure_text(text, font_size, bold, italic) -> width
--   freak_ui_get_width(handle) -> int
--   freak_ui_get_height(handle) -> int
--   freak_ui_destroy_window(handle)

shape Window {
    handle: int
    width:  int
    height: int
}

impl Window {
    task open(config: WindowConfig) -> Window {
        pilot resizable = 1
        if not config.resizable { resizable = 0 }
        pilot h = ui::create_window(config.title, config.width, config.height, resizable)
        give back Window { handle: h, width: config.width, height: config.height }
    }

    task close(self) -> void {
        ui::destroy_window(self.handle)
    }

    -- Poll events for this frame. Returns a list of events.
    -- If quit was requested, the list will contain an EVENT_QUIT event.
    task poll(self) -> List<Event> {
        pilot events = []
        pilot count = ui::poll_events(self.handle)

        if count < 0 {
            -- Quit requested
            events.push(Event {
                kind: EVENT_QUIT, key: 0, pressed: 0, key_repeat: 0,
                character: 0, mouse_x: 0, mouse_y: 0, button: 0,
                scroll_dy: 0, width: 0, height: 0, gained: 0
            })
            give back events
        }

        pilot i = 0
        repeat count times {
            pilot ev = Event {
                kind:      ui::event_kind(i),
                key:       ui::event_key(i),
                pressed:   ui::event_pressed(i),
                key_repeat:    ui::event_repeat(i),
                character: ui::event_character(i),
                mouse_x:   ui::event_mouse_x(i),
                mouse_y:   ui::event_mouse_y(i),
                button:    ui::event_button(i),
                scroll_dy: ui::event_scroll_dy(i),
                width:     ui::event_width(i),
                height:    ui::event_height(i),
                gained:    ui::event_gained(i)
            }
            events.push(ev)
            i = i + 1
        }
        give back events
    }
}

-- ================================================================
--  Canvas — drawing commands for the current frame
-- ================================================================

shape Canvas {
    handle: int
}

impl Canvas {
    task from_window(win: Window) -> Canvas {
        give back Canvas { handle: win.handle }
    }

    task begin(self) -> void {
        ui::begin_frame(self.handle)
    }

    task finish(self) -> void {
        ui::end_frame(self.handle)
    }

    task clear(self, color: Color) -> void {
        ui::clear(self.handle, color.r, color.g, color.b, color.a)
    }

    task fill_rect(self, rect: Rect, color: Color) -> void {
        ui::fill_rect(self.handle, rect.x, rect.y, rect.w, rect.h, color.r, color.g, color.b, color.a)
    }

    task stroke_rect(self, rect: Rect, color: Color, thickness: int) -> void {
        ui::stroke_rect(self.handle, rect.x, rect.y, rect.w, rect.h, color.r, color.g, color.b, color.a, thickness)
    }

    task fill_circle(self, center: Vec2, radius: int, color: Color) -> void {
        ui::fill_circle(self.handle, center.x, center.y, radius, color.r, color.g, color.b, color.a)
    }

    task draw_line(self, from: Vec2, to: Vec2, color: Color, thickness: int) -> void {
        ui::draw_line(self.handle, from.x, from.y, to.x, to.y, color.r, color.g, color.b, color.a, thickness)
    }

    task draw_text(self, text: word, x: int, y: int, font: Font, color: Color) -> int {
        give back ui::draw_text(self.handle, text, x, y, color.r, color.g, color.b, font.size, font.bold, font.italic)
    }

    task width(self) -> int {
        give back ui::get_width(self.handle)
    }

    task height(self) -> int {
        give back ui::get_height(self.handle)
    }
}
-- freak-ui: Layout Engine (Phase B)
-- Immediate-mode flex-like layout system.
--
-- Layout works via a cursor stack. Each frame starts with a root layout
-- context. Widgets consume space from the current context. `row` and
-- `column` push/pop layout contexts.
--
-- No widget trees. No retained state. Just a cursor that moves.


-- ================================================================
--  Size hints — how a widget wants to be sized
-- ================================================================

-- Size hint constants
fixed pilot SIZE_AUTO     = 0   -- fit content
fixed pilot SIZE_FILL     = 1   -- fill remaining space
fixed pilot SIZE_FIXED    = 2   -- exact pixel value
fixed pilot SIZE_FRACTION = 3   -- fraction of available space

shape SizeHint {
    kind:  int
    value: num
}

impl SizeHint {
    task auto() -> SizeHint {
        give back SizeHint { kind: SIZE_AUTO, value: 0.0 }
    }

    task fill() -> SizeHint {
        give back SizeHint { kind: SIZE_FILL, value: 0.0 }
    }

    task fixed(px: num) -> SizeHint {
        give back SizeHint { kind: SIZE_FIXED, value: px }
    }

    task fraction(f: num) -> SizeHint {
        give back SizeHint { kind: SIZE_FRACTION, value: f }
    }

    -- Resolve a size hint to actual pixels
    task resolve(self, available: num, content: num) -> num {
        if self.kind == SIZE_AUTO {
            give back content
        }
        if self.kind == SIZE_FILL {
            give back available
        }
        if self.kind == SIZE_FIXED {
            give back self.value
        }
        if self.kind == SIZE_FRACTION {
            give back available * self.value
        }
        give back content
    }
}

-- ================================================================
--  Layout direction
-- ================================================================

fixed pilot DIR_VERTICAL   = 0
fixed pilot DIR_HORIZONTAL = 1

-- ================================================================
--  Layout context — one entry on the layout stack
-- ================================================================

shape LayoutContext {
    -- Bounding box for this context
    x:      num
    y:      num
    max_w:  num
    max_h:  num

    -- Current cursor position within the context
    cursor_x: num
    cursor_y: num

    -- Direction: vertical (column) or horizontal (row)
    direction: int

    -- Spacing between widgets
    gap:     num

    -- Padding inside the context
    pad:     num

    -- Track how many widgets placed (for gap calculation)
    count:   int

    -- Track maximum cross-axis size (for row: tallest widget, for column: widest)
    cross_max: num
}

impl LayoutContext {
    task new(x: num, y: num, w: num, h: num, dir: int, gap: num, pad: num) -> LayoutContext {
        give back LayoutContext {
            x:         x + pad,
            y:         y + pad,
            max_w:     w - pad * 2.0,
            max_h:     h - pad * 2.0,
            cursor_x:  x + pad,
            cursor_y:  y + pad,
            direction: dir,
            gap:       gap,
            pad:       pad,
            count:     0,
            cross_max: 0.0
        }
    }

    -- Get the remaining width available for the next widget
    task remaining_width(self) -> num {
        if self.direction == DIR_HORIZONTAL {
            pilot used = self.cursor_x - self.x
            give back self.max_w - used
        }
        give back self.max_w
    }

    -- Get the remaining height available for the next widget
    task remaining_height(self) -> num {
        if self.direction == DIR_VERTICAL {
            pilot used = self.cursor_y - self.y
            give back self.max_h - used
        }
        give back self.max_h
    }

    -- Allocate space for a widget and return its bounding rect.
    -- Advances the cursor after allocation.
    task allocate(self, w: num, h: num) -> Rect {
        -- Add gap before non-first widgets
        if self.count > 0 {
            if self.direction == DIR_HORIZONTAL {
                self.cursor_x = self.cursor_x + self.gap
            } else {
                self.cursor_y = self.cursor_y + self.gap
            }
        }

        pilot rect = Rect {
            x: self.cursor_x,
            y: self.cursor_y,
            w: w,
            h: h
        }

        -- Advance cursor
        if self.direction == DIR_HORIZONTAL {
            self.cursor_x = self.cursor_x + w
            if h > self.cross_max {
                self.cross_max = h
            }
        } else {
            self.cursor_y = self.cursor_y + h
            if w > self.cross_max {
                self.cross_max = w
            }
        }

        self.count = self.count + 1
        give back rect
    }

    -- Get the total size consumed by all widgets so far
    task consumed_width(self) -> num {
        if self.direction == DIR_HORIZONTAL {
            give back self.cursor_x - self.x
        }
        give back self.cross_max
    }

    task consumed_height(self) -> num {
        if self.direction == DIR_VERTICAL {
            give back self.cursor_y - self.y
        }
        give back self.cross_max
    }
}

-- ================================================================
--  Layout stack — manages nested layout contexts
-- ================================================================

-- Maximum nesting depth for layout contexts
fixed pilot MAX_LAYOUT_DEPTH = 32

shape LayoutStack {
    -- Flat arrays for the layout stack (since we can't have List<LayoutContext>
    -- easily in the C backend, we use parallel arrays)
    ctx_x:         List<num>
    ctx_y:         List<num>
    ctx_max_w:     List<num>
    ctx_max_h:     List<num>
    ctx_cursor_x:  List<num>
    ctx_cursor_y:  List<num>
    ctx_direction: List<int>
    ctx_gap:       List<num>
    ctx_pad:       List<num>
    ctx_count:     List<int>
    ctx_cross_max: List<num>
    depth:         int
}

impl LayoutStack {
    task new() -> LayoutStack {
        give back LayoutStack {
            ctx_x:         [],
            ctx_y:         [],
            ctx_max_w:     [],
            ctx_max_h:     [],
            ctx_cursor_x:  [],
            ctx_cursor_y:  [],
            ctx_direction: [],
            ctx_gap:       [],
            ctx_pad:       [],
            ctx_count:     [],
            ctx_cross_max: [],
            depth:         0
        }
    }

    -- Push a new layout context onto the stack
    task push(self, x: num, y: num, w: num, h: num, dir: int, gap: num, pad: num) -> void {
        pilot px = x + pad
        pilot py = y + pad
        pilot pw = w - pad * 2.0
        pilot ph = h - pad * 2.0

        self.ctx_x.push(px)
        self.ctx_y.push(py)
        self.ctx_max_w.push(pw)
        self.ctx_max_h.push(ph)
        self.ctx_cursor_x.push(px)
        self.ctx_cursor_y.push(py)
        self.ctx_direction.push(dir)
        self.ctx_gap.push(gap)
        self.ctx_pad.push(pad)
        self.ctx_count.push(0)
        self.ctx_cross_max.push(0.0)
        self.depth = self.depth + 1
    }

    -- Pop the top layout context, returning consumed size as (width, height)
    task pop(self) -> Vec2 {
        pilot i = self.depth - 1
        pilot dir = self.ctx_direction[i]
        pilot consumed_w = 0.0
        pilot consumed_h = 0.0

        if dir == DIR_HORIZONTAL {
            consumed_w = self.ctx_cursor_x[i] - self.ctx_x[i]
            consumed_h = self.ctx_cross_max[i]
        } else {
            consumed_w = self.ctx_cross_max[i]
            consumed_h = self.ctx_cursor_y[i] - self.ctx_y[i]
        }

        -- Add padding back
        pilot pad = self.ctx_pad[i]
        consumed_w = consumed_w + pad * 2.0
        consumed_h = consumed_h + pad * 2.0

        self.depth = self.depth - 1
        give back Vec2 { x: consumed_w, y: consumed_h }
    }

    -- Get remaining width in current context
    task remaining_width(self) -> num {
        pilot i = self.depth - 1
        if self.ctx_direction[i] == DIR_HORIZONTAL {
            pilot used = self.ctx_cursor_x[i] - self.ctx_x[i]
            give back self.ctx_max_w[i] - used
        }
        give back self.ctx_max_w[i]
    }

    -- Get remaining height in current context
    task remaining_height(self) -> num {
        pilot i = self.depth - 1
        if self.ctx_direction[i] == DIR_VERTICAL {
            pilot used = self.ctx_cursor_y[i] - self.ctx_y[i]
            give back self.ctx_max_h[i] - used
        }
        give back self.ctx_max_h[i]
    }

    -- Allocate a rect in the current context
    task allocate(self, w: num, h: num) -> Rect {
        pilot i = self.depth - 1

        -- Add gap before non-first widgets
        if self.ctx_count[i] > 0 {
            if self.ctx_direction[i] == DIR_HORIZONTAL {
                self.ctx_cursor_x[i] = self.ctx_cursor_x[i] + self.ctx_gap[i]
            } else {
                self.ctx_cursor_y[i] = self.ctx_cursor_y[i] + self.ctx_gap[i]
            }
        }

        pilot rect = Rect {
            x: self.ctx_cursor_x[i],
            y: self.ctx_cursor_y[i],
            w: w,
            h: h
        }

        -- Advance cursor
        if self.ctx_direction[i] == DIR_HORIZONTAL {
            self.ctx_cursor_x[i] = self.ctx_cursor_x[i] + w
            if h > self.ctx_cross_max[i] {
                self.ctx_cross_max[i] = h
            }
        } else {
            self.ctx_cursor_y[i] = self.ctx_cursor_y[i] + h
            if w > self.ctx_cross_max[i] {
                self.ctx_cross_max[i] = w
            }
        }

        self.ctx_count[i] = self.ctx_count[i] + 1
        give back rect
    }

    -- Get current cursor position
    task cursor(self) -> Vec2 {
        pilot i = self.depth - 1
        give back Vec2 {
            x: self.ctx_cursor_x[i],
            y: self.ctx_cursor_y[i]
        }
    }

    -- Get the current context's direction
    task current_direction(self) -> int {
        give back self.ctx_direction[self.depth - 1]
    }

    -- Get the current context's available width
    task current_width(self) -> num {
        give back self.ctx_max_w[self.depth - 1]
    }
}
-- freak-ui: Theme System (Phase D)
-- Five built-in themes, each with a mood. Custom themes supported.
--
-- "Every UI has a feeling. We just made it explicit."


-- ================================================================
--  Theme shape
-- ================================================================

shape Theme {
    name:       word
    bg:         Color
    bg2:        Color
    surface:    Color
    border:     Color
    text:       Color
    text_muted: Color
    accent:     Color
    accent_hover: Color
    danger:     Color
    success:    Color
    font_size:  int
    font_bold:  bool
    mono_size:  int
    radius:     int
    padding:    int
    gap:        int
    shadow:     bool
}

impl Theme {
    -- Clean dark theme. Professional. Ready.
    task default() -> Theme {
        give back Theme {
            name:         "default",
            bg:           Color::rgb(22, 22, 30),
            bg2:          Color::rgb(30, 30, 42),
            surface:      Color::rgb(38, 38, 54),
            border:       Color::rgb(58, 58, 78),
            text:         Color::rgb(230, 230, 240),
            text_muted:   Color::rgb(128, 128, 160),
            accent:       Color::rgb(100, 140, 255),
            accent_hover: Color::rgb(130, 165, 255),
            danger:       Color::rgb(255, 80, 80),
            success:      Color::rgb(80, 200, 120),
            font_size:    14,
            font_bold:    false,
            mono_size:    13,
            radius:       6,
            padding:      12,
            gap:          8,
            shadow:       true
        }
    }

    -- Clean light theme. Calm. Readable.
    task light() -> Theme {
        give back Theme {
            name:         "light",
            bg:           Color::rgb(245, 245, 248),
            bg2:          Color::rgb(235, 235, 240),
            surface:      Color::rgb(255, 255, 255),
            border:       Color::rgb(210, 210, 220),
            text:         Color::rgb(30, 30, 40),
            text_muted:   Color::rgb(120, 120, 140),
            accent:       Color::rgb(60, 100, 220),
            accent_hover: Color::rgb(80, 120, 240),
            danger:       Color::rgb(220, 50, 50),
            success:      Color::rgb(40, 160, 80),
            font_size:    14,
            font_bold:    false,
            mono_size:    13,
            radius:       6,
            padding:      12,
            gap:          8,
            shadow:       true
        }
    }

    -- Green on black. Pure hacker energy.
    task terminal() -> Theme {
        give back Theme {
            name:         "terminal",
            bg:           Color::rgb(0, 0, 0),
            bg2:          Color::rgb(10, 10, 10),
            surface:      Color::rgb(15, 15, 15),
            border:       Color::rgb(0, 80, 0),
            text:         Color::rgb(0, 220, 0),
            text_muted:   Color::rgb(0, 140, 0),
            accent:       Color::rgb(0, 255, 0),
            accent_hover: Color::rgb(80, 255, 80),
            danger:       Color::rgb(255, 0, 0),
            success:      Color::rgb(0, 255, 0),
            font_size:    13,
            font_bold:    false,
            mono_size:    13,
            radius:       0,
            padding:      8,
            gap:          4,
            shadow:       false
        }
    }

    -- Deep navy and pink. Beautiful. Dangerous.
    task alternative() -> Theme {
        give back Theme {
            name:         "alternative",
            bg:           Color::rgb(12, 15, 35),
            bg2:          Color::rgb(18, 22, 48),
            surface:      Color::rgb(25, 30, 60),
            border:       Color::rgb(60, 50, 100),
            text:         Color::rgb(220, 220, 240),
            text_muted:   Color::rgb(140, 130, 180),
            accent:       Color::rgb(255, 45, 120),
            accent_hover: Color::rgb(255, 80, 150),
            danger:       Color::rgb(255, 60, 60),
            success:      Color::rgb(60, 220, 160),
            font_size:    14,
            font_bold:    false,
            mono_size:    13,
            radius:       8,
            padding:      14,
            gap:          10,
            shadow:       true
        }
    }

    -- Blood red and black. You know what you've done.
    task muvluv() -> Theme {
        give back Theme {
            name:         "muvluv",
            bg:           Color::rgb(10, 0, 0),
            bg2:          Color::rgb(20, 5, 5),
            surface:      Color::rgb(30, 8, 8),
            border:       Color::rgb(100, 20, 20),
            text:         Color::rgb(220, 200, 200),
            text_muted:   Color::rgb(150, 100, 100),
            accent:       Color::rgb(200, 20, 20),
            accent_hover: Color::rgb(240, 50, 50),
            danger:       Color::rgb(255, 0, 0),
            success:      Color::rgb(180, 180, 60),
            font_size:    14,
            font_bold:    false,
            mono_size:    13,
            radius:       2,
            padding:      10,
            gap:          6,
            shadow:       true
        }
    }

    -- Create a theme with a custom accent color
    task with_accent(self, color: Color) -> Theme {
        give back Theme {
            name:         self.name,
            bg:           self.bg,
            bg2:          self.bg2,
            surface:      self.surface,
            border:       self.border,
            text:         self.text,
            text_muted:   self.text_muted,
            accent:       color,
            accent_hover: Color::rgb(
                min(color.r + 30, 255),
                min(color.g + 30, 255),
                min(color.b + 30, 255)
            ),
            danger:       self.danger,
            success:      self.success,
            font_size:    self.font_size,
            font_bold:    self.font_bold,
            mono_size:    self.mono_size,
            radius:       self.radius,
            padding:      self.padding,
            gap:          self.gap,
            shadow:       self.shadow
        }
    }
}

-- Helper
task min(a: int, b: int) -> int {
    if a < b { give back a }
    give back b
}
-- freak-ui: Core Widgets (Phase C)
-- Immediate-mode widgets: label, button, input, spacer, separator
--
-- Every widget follows the same pattern:
--   1. Measure content size
--   2. Allocate space from layout
--   3. Draw to canvas
--   4. Check input (for interactive widgets)
--   5. Return interaction result


-- ================================================================
--  Widget style constants
-- ================================================================

-- Label styles
fixed pilot LABEL_NORMAL     = 0
fixed pilot LABEL_HEADING    = 1
fixed pilot LABEL_SUBHEADING = 2
fixed pilot LABEL_DISPLAY    = 3
fixed pilot LABEL_MONO       = 4
fixed pilot LABEL_MUTED      = 5

-- Button styles
fixed pilot BTN_NORMAL   = 0
fixed pilot BTN_PRIMARY  = 1
fixed pilot BTN_DANGER   = 2
fixed pilot BTN_OPERATOR = 3
fixed pilot BTN_EQUALS   = 4
fixed pilot BTN_GHOST    = 5

-- ================================================================
--  Label — display text, no interaction
-- ================================================================

-- Measure text width (approximate: ~7px per char at size 14)
task measure_text_width(text: word, font_size: int) -> int {
    pilot char_width = font_size * 6 / 10
    if char_width < 1 { char_width = 7 }
    give back text.len() * char_width + 4
}

task label_sized(canvas: Canvas, text: word, rect: Rect, style: int,
                 text_color: Color, muted_color: Color, font_size: int) -> void {
    pilot color = text_color
    pilot size = font_size
    pilot bold = 0
    pilot italic = 0

    if style == LABEL_HEADING {
        size = 24
        bold = 1
    }
    if style == LABEL_SUBHEADING {
        size = 18
        bold = 1
    }
    if style == LABEL_DISPLAY {
        size = 36
        bold = 1
    }
    if style == LABEL_MONO {
        size = 13
    }
    if style == LABEL_MUTED {
        color = muted_color
    }

    canvas.draw_text(text, rect.x, rect.y, Font { size: size, bold: bold, italic: italic }, color)
}

-- Get height for a label style
task label_height(style: int, base_size: int) -> int {
    if style == LABEL_HEADING    { give back 30 }
    if style == LABEL_SUBHEADING { give back 24 }
    if style == LABEL_DISPLAY    { give back 44 }
    give back base_size + 6
}

-- ================================================================
--  Button — clickable rectangle, returns true on click
-- ================================================================

shape ButtonResult {
    clicked:  bool
    hovered:  bool
}

task button_check(rect: Rect, mouse_x: int, mouse_y: int, mouse_down: bool, mouse_clicked: bool) -> ButtonResult {
    pilot hovered = rect.contains(mouse_x, mouse_y)
    pilot clicked = hovered and mouse_clicked
    give back ButtonResult { clicked: clicked, hovered: hovered }
}

task button_draw(canvas: Canvas, text: word, rect: Rect, style: int, hovered: bool,
                 theme_surface: Color, theme_accent: Color, theme_accent_hover: Color,
                 theme_danger: Color, theme_text: Color, theme_border: Color,
                 theme_radius: int, font_size: int) -> void {
    -- Determine colors based on style
    pilot bg = theme_surface
    pilot fg = theme_text
    pilot border = theme_border

    if style == BTN_PRIMARY {
        bg = theme_accent
        fg = Color::rgb(255, 255, 255)
        border = theme_accent
    }
    if style == BTN_DANGER {
        bg = theme_danger
        fg = Color::rgb(255, 255, 255)
        border = theme_danger
    }
    if style == BTN_OPERATOR {
        bg = Color::rgb(
            theme_accent.r / 3,
            theme_accent.g / 3,
            theme_accent.b / 3
        )
        fg = theme_accent
        border = theme_accent
    }
    if style == BTN_EQUALS {
        bg = theme_accent
        fg = Color::rgb(255, 255, 255)
        border = theme_accent
    }
    if style == BTN_GHOST {
        bg = Color::rgba(0, 0, 0, 0)
        border = Color::rgba(0, 0, 0, 0)
    }

    -- Hover brightening
    if hovered {
        if style == BTN_PRIMARY or style == BTN_EQUALS {
            bg = theme_accent_hover
        } else {
            if style != BTN_GHOST {
                bg = Color::rgb(
                    min_i(bg.r + 15, 255),
                    min_i(bg.g + 15, 255),
                    min_i(bg.b + 15, 255)
                )
            }
        }
    }

    -- Draw background
    canvas.fill_rect(rect, bg)

    -- Draw border
    if style != BTN_GHOST {
        canvas.stroke_rect(rect, border, 1)
    }

    -- Draw text centered
    pilot text_w = measure_text_width(text, font_size)
    pilot text_x = rect.x + (rect.w - text_w) / 2
    pilot text_y = rect.y + (rect.h - font_size) / 2
    canvas.draw_text(text, text_x, text_y, Font { size: font_size, bold: false, italic: false }, fg)
}

-- ================================================================
--  Input — text field
-- ================================================================

shape InputState {
    cursor_pos: int
    focused:    bool
}

impl InputState {
    task new() -> InputState {
        give back InputState { cursor_pos: 0, focused: false }
    }
}

task input_draw(canvas: Canvas, value: word, rect: Rect, placeholder: word,
                focused: bool, cursor_pos: int,
                theme_bg: Color, theme_surface: Color, theme_border: Color,
                theme_accent: Color, theme_text: Color, theme_muted: Color,
                font_size: int) -> void {
    -- Background
    canvas.fill_rect(rect, theme_bg)

    -- Border (accent if focused)
    pilot border_color = theme_border
    if focused {
        border_color = theme_accent
    }
    canvas.stroke_rect(rect, border_color, 1)

    -- Text or placeholder
    pilot text_x = rect.x + 8
    pilot text_y = rect.y + (rect.h - font_size) / 2

    if value.len() == 0 {
        canvas.draw_text(placeholder, text_x, text_y,
            Font { size: font_size, bold: false, italic: false }, theme_muted)
    } else {
        canvas.draw_text(value, text_x, text_y,
            Font { size: font_size, bold: false, italic: false }, theme_text)
    }

    -- Cursor (blinking would need frame counter, for now always show when focused)
    if focused {
        pilot cursor_x = text_x + measure_text_width(value.substring(0, cursor_pos), font_size)
        canvas.fill_rect(Rect { x: cursor_x, y: rect.y + 4, w: 2, h: rect.h - 8 }, theme_accent)
    }
}

-- ================================================================
--  Spacer — empty space
-- ================================================================

-- Spacer is handled purely in layout (allocate space, draw nothing)

-- ================================================================
--  Separator — horizontal or vertical line
-- ================================================================

task separator_draw(canvas: Canvas, rect: Rect, color: Color) -> void {
    pilot y = rect.y + rect.h / 2
    canvas.draw_line(
        Vec2 { x: rect.x, y: y },
        Vec2 { x: rect.x + rect.w, y: y },
        color, 1
    )
}

-- ================================================================
--  Dropdown — draw helpers
-- ================================================================

task dropdown_draw(canvas: Canvas, items: List<word>, selected: int, rect: Rect,
                   is_open: bool, hover_index: int,
                   theme_surface: Color, theme_bg2: Color, theme_border: Color,
                   theme_accent: Color, theme_text: Color, theme_muted: Color,
                   font_size: int, item_h: int) -> void {
    -- Draw the closed dropdown button
    canvas.fill_rect(rect, theme_surface)
    canvas.stroke_rect(rect, theme_border, 1)

    -- Selected text
    pilot text_x = rect.x + 8
    pilot text_y = rect.y + (rect.h - font_size) / 2
    if selected >= 0 and selected < items.len() {
        canvas.draw_text(items[selected], text_x, text_y,
            Font { size: font_size, bold: false, italic: false }, theme_text)
    } else {
        canvas.draw_text("(none)", text_x, text_y,
            Font { size: font_size, bold: false, italic: false }, theme_muted)
    }

    -- Down arrow indicator
    pilot arrow_x = rect.x + rect.w - 20
    canvas.draw_text("v", arrow_x, text_y,
        Font { size: font_size, bold: false, italic: false }, theme_muted)

    -- If open, draw the option list overlay
    if is_open {
        pilot list_y = rect.y + rect.h
        pilot list_h = items.len() * item_h

        -- Background
        pilot list_rect = Rect { x: rect.x, y: list_y, w: rect.w, h: list_h }
        canvas.fill_rect(list_rect, theme_bg2)
        canvas.stroke_rect(list_rect, theme_border, 1)

        -- Items
        pilot i = 0
        repeat items.len() times {
            pilot iy = list_y + i * item_h
            pilot item_rect = Rect { x: rect.x, y: iy, w: rect.w, h: item_h }

            -- Highlight hovered item
            if i == hover_index {
                canvas.fill_rect(item_rect, theme_accent)
                canvas.draw_text(items[i], rect.x + 8, iy + (item_h - font_size) / 2,
                    Font { size: font_size, bold: false, italic: false },
                    Color::rgb(255, 255, 255))
            } else {
                canvas.draw_text(items[i], rect.x + 8, iy + (item_h - font_size) / 2,
                    Font { size: font_size, bold: false, italic: false }, theme_text)
            }
            i = i + 1
        }
    }
}

-- ================================================================
--  Tabs — draw helpers
-- ================================================================

task tabs_draw(canvas: Canvas, names: List<word>, selected: int, rect: Rect,
               hover_index: int,
               theme_surface: Color, theme_bg: Color, theme_border: Color,
               theme_accent: Color, theme_text: Color, theme_muted: Color,
               font_size: int) -> void {
    -- Draw tab bar background
    canvas.fill_rect(rect, theme_bg)

    -- Draw each tab
    pilot tab_w = rect.w / names.len()
    pilot i = 0
    repeat names.len() times {
        pilot tx = rect.x + i * tab_w
        pilot tab_rect = Rect { x: tx, y: rect.y, w: tab_w, h: rect.h }

        -- Selected tab highlight
        if i == selected {
            canvas.fill_rect(tab_rect, theme_surface)
            -- Accent underline
            pilot underline = Rect { x: tx, y: rect.y + rect.h - 3, w: tab_w, h: 3 }
            canvas.fill_rect(underline, theme_accent)
        }

        -- Hover highlight (non-selected)
        if i == hover_index and i != selected {
            pilot hover_bg = Color::rgb(
                min_i(theme_bg.r + 15, 255),
                min_i(theme_bg.g + 15, 255),
                min_i(theme_bg.b + 15, 255)
            )
            canvas.fill_rect(tab_rect, hover_bg)
        }

        -- Tab text
        pilot text_w = measure_text_width(names[i], font_size)
        pilot text_x = tx + (tab_w - text_w) / 2
        pilot text_y = rect.y + (rect.h - font_size) / 2
        pilot text_color = theme_muted
        if i == selected { text_color = theme_text }
        canvas.draw_text(names[i], text_x, text_y,
            Font { size: font_size, bold: i == selected, italic: false }, text_color)

        i = i + 1
    }

    -- Bottom border
    pilot bottom = Rect { x: rect.x, y: rect.y + rect.h - 1, w: rect.w, h: 1 }
    canvas.fill_rect(bottom, theme_border)
}

-- ================================================================
--  Progress bar — draw helper
-- ================================================================

task progress_draw(canvas: Canvas, value: num, rect: Rect, label: word,
                   theme_bg2: Color, theme_accent: Color, theme_text: Color,
                   font_size: int) -> void {
    -- Track background
    canvas.fill_rect(rect, theme_bg2)

    -- Fill
    pilot clamped = value
    if clamped < 0.0 { clamped = 0.0 }
    if clamped > 1.0 { clamped = 1.0 }
    pilot fill_w = rect.w * clamped
    if fill_w > 0.0 {
        pilot fill_rect = Rect { x: rect.x, y: rect.y, w: fill_w, h: rect.h }
        canvas.fill_rect(fill_rect, theme_accent)
    }

    -- Label centered
    if label.len() > 0 {
        pilot text_w = measure_text_width(label, font_size)
        pilot text_x = rect.x + (rect.w - text_w) / 2
        pilot text_y = rect.y + (rect.h - font_size) / 2
        canvas.draw_text(label, text_x, text_y,
            Font { size: font_size, bold: false, italic: false }, theme_text)
    }
}

-- ================================================================
--  Tooltip — draw helper
-- ================================================================

task tooltip_draw(canvas: Canvas, text: word, anchor_x: int, anchor_y: int,
                  theme_surface: Color, theme_border: Color, theme_text: Color,
                  font_size: int) -> void {
    pilot pad = 6
    pilot text_w = measure_text_width(text, font_size) + pad * 2
    pilot text_h = font_size + pad * 2

    -- Position above the anchor point
    pilot tx = anchor_x
    pilot ty = anchor_y - text_h - 4

    pilot bg_rect = Rect { x: tx, y: ty, w: text_w, h: text_h }
    canvas.fill_rect(bg_rect, theme_surface)
    canvas.stroke_rect(bg_rect, theme_border, 1)
    canvas.draw_text(text, tx + pad, ty + pad,
        Font { size: font_size, bold: false, italic: false }, theme_text)
}

-- ================================================================
--  Modal overlay — draw helper
-- ================================================================

task modal_overlay_draw(canvas: Canvas, win_w: int, win_h: int,
                        panel_w: int, panel_h: int,
                        theme_bg: Color, theme_surface: Color, theme_border: Color) -> Rect {
    -- Darken background
    pilot overlay = Rect { x: 0, y: 0, w: win_w, h: win_h }
    canvas.fill_rect(overlay, Color::rgba(0, 0, 0, 160))

    -- Centered panel
    pilot px = (win_w - panel_w) / 2
    pilot py = (win_h - panel_h) / 2
    pilot panel = Rect { x: px, y: py, w: panel_w, h: panel_h }
    canvas.fill_rect(panel, theme_surface)
    canvas.stroke_rect(panel, theme_border, 1)

    give back panel
}

-- ================================================================
--  Helpers
-- ================================================================

task min_i(a: int, b: int) -> int {
    if a < b { give back a }
    give back b
}

task max_i(a: int, b: int) -> int {
    if a > b { give back a }
    give back b
}

task clamp_f(v: num, lo: num, hi: num) -> num {
    if v < lo { give back lo }
    if v > hi { give back hi }
    give back v
}
-- freak-ui: Main UI Shape
-- The immediate-mode state machine that drives everything.
--
-- Usage:
--   pilot ui = UI::new(window, Theme::default())
--   -- in your main loop:
--   ui.begin_frame()
--   ui.label("Hello")
--   if ui.button("Click me") { ... }
--   ui.end_frame()

              EVENT_NONE, EVENT_QUIT, EVENT_KEY, EVENT_CHAR, EVENT_MOUSE,
              EVENT_SCROLL, EVENT_RESIZE, EVENT_FOCUS,
              MOUSE_LEFT, MOUSE_RIGHT, KEY_BACKSPACE, KEY_DELETE,
              KEY_LEFT, KEY_RIGHT, KEY_ENTER, KEY_TAB, KEY_ESCAPE}

-- Easing function constants
fixed pilot EASE_LINEAR      = 0
fixed pilot EASE_IN          = 1
fixed pilot EASE_OUT         = 2
fixed pilot EASE_IN_OUT      = 3
fixed pilot EASE_SPRING      = 4

-- ================================================================
--  UI — the immediate mode state machine
-- ================================================================

shape UI {
    -- Window reference
    window: Window
    canvas: Canvas

    -- Theme
    theme: Theme

    -- Layout stack (parallel arrays)
    layout: LayoutStack

    -- Input state (updated each frame from events)
    mouse_x:       int
    mouse_y:       int
    mouse_down:    bool
    mouse_clicked: bool   -- true only on the frame the button was pressed
    mouse_released: bool  -- true only on the frame the button was released

    -- Keyboard
    key_pressed:     int   -- key code pressed this frame (0 = none)
    char_typed:      int   -- character typed this frame (0 = none)
    key_backspace:   bool
    key_delete:      bool
    key_left:        bool
    key_right:       bool
    key_enter:       bool
    key_tab:         bool
    key_escape:      bool

    -- Focus tracking
    focus_id:        int   -- which widget has focus (by widget index)
    widget_count:    int   -- total widgets this frame (auto-increments)

    -- Frame state
    frame_count:     int
    should_quit:     bool

    -- Active input field state
    input_cursor:    int
    input_focus_id:  int

    -- Scroll input
    scroll_delta:      int   -- mouse wheel delta this frame

    -- Dropdown state
    dropdown_open_id:  int   -- which dropdown is open (-1 = none)

    -- Scroll state (per-widget, up to 16 scrollable regions)
    scroll_offsets:    List<num>
    scroll_count:      int

    -- Animation / frame timing
    last_frame_time:   num   -- timestamp of previous frame (ms)
    delta_time:        num   -- seconds since last frame

    -- Tween state (up to 32 active tweens)
    tween_ids:         List<int>
    tween_currents:    List<num>
    tween_targets:     List<num>
    tween_speeds:      List<num>
    tween_easings:     List<int>
    tween_count:       int

    -- Tooltip state (drawn at end of frame, on top of everything)
    tooltip_text:      word
    tooltip_x:         int
    tooltip_y:         int
    tooltip_active:    bool

    -- Modal state
    modal_open:        bool
}

impl UI {
    task new(win: Window, theme: Theme) -> UI {
        give back UI {
            window:         win,
            canvas:         Canvas::from_window(win),
            theme:          theme,
            layout:         LayoutStack::new(),
            mouse_x:        0,
            mouse_y:        0,
            mouse_down:     false,
            mouse_clicked:  false,
            mouse_released: false,
            key_pressed:    0,
            char_typed:     0,
            key_backspace:  false,
            key_delete:     false,
            key_left:       false,
            key_right:      false,
            key_enter:      false,
            key_tab:        false,
            key_escape:     false,
            focus_id:       -1,
            widget_count:   0,
            frame_count:    0,
            should_quit:    false,
            input_cursor:   0,
            input_focus_id: -1,
            scroll_delta:   0,
            dropdown_open_id: -1,
            scroll_offsets:   [],
            scroll_count:     0,
            last_frame_time:  0.0,
            delta_time:       0.0,
            tween_ids:        [],
            tween_currents:   [],
            tween_targets:    [],
            tween_speeds:     [],
            tween_easings:    [],
            tween_count:      0,
            tooltip_text:     "",
            tooltip_x:        0,
            tooltip_y:        0,
            tooltip_active:   false,
            modal_open:       false
        }
    }

    -- ============================================================
    --  Frame lifecycle
    -- ============================================================

    task begin_frame(self) -> List<Event> {
        -- Poll events
        pilot events = self.window.poll()

        -- Reset per-frame input state
        self.mouse_clicked  = false
        self.mouse_released = false
        self.key_pressed    = 0
        self.char_typed     = 0
        self.key_backspace  = false
        self.key_delete     = false
        self.key_left       = false
        self.key_right      = false
        self.key_enter      = false
        self.key_tab        = false
        self.key_escape     = false
        self.widget_count   = 0
        self.tooltip_active = false
        self.scroll_count   = 0
        self.scroll_delta   = 0

        -- Process events
        pilot i = 0
        repeat events.len() times {
            pilot ev = events[i]
            if ev.kind == EVENT_QUIT {
                self.should_quit = true
            }
            if ev.kind == EVENT_MOUSE {
                self.mouse_x = ev.mouse_x
                self.mouse_y = ev.mouse_y
                if ev.button == MOUSE_LEFT {
                    if ev.pressed == 1 {
                        self.mouse_down = true
                        self.mouse_clicked = true
                    } else {
                        self.mouse_down = false
                        self.mouse_released = true
                    }
                }
            }
            if ev.kind == EVENT_KEY {
                if ev.pressed == 1 {
                    self.key_pressed = ev.key
                    if ev.key == KEY_BACKSPACE { self.key_backspace = true }
                    if ev.key == KEY_DELETE    { self.key_delete = true }
                    if ev.key == KEY_LEFT      { self.key_left = true }
                    if ev.key == KEY_RIGHT     { self.key_right = true }
                    if ev.key == KEY_ENTER     { self.key_enter = true }
                    if ev.key == KEY_TAB       { self.key_tab = true }
                    if ev.key == KEY_ESCAPE    { self.key_escape = true }
                }
            }
            if ev.kind == EVENT_CHAR {
                self.char_typed = ev.character
            }
            if ev.kind == EVENT_SCROLL {
                self.scroll_delta = self.scroll_delta + ev.scroll_dy
            }
            if ev.kind == EVENT_RESIZE {
                self.window.width = ev.width
                self.window.height = ev.height
            }
            i = i + 1
        }

        -- Begin canvas frame
        self.canvas.begin()

        -- Clear with theme background
        self.canvas.clear(self.theme.bg)

        -- Push root layout context (full window, vertical, theme gap/padding)
        self.layout = LayoutStack::new()
        self.layout.push(
            0.0, 0.0,
            self.window.width, self.window.height,
            DIR_VERTICAL,
            self.theme.gap,
            self.theme.padding
        )

        give back events
    }

    task end_frame(self) -> void {
        -- Pop root layout
        if self.layout.depth > 0 {
            self.layout.pop()
        }

        -- Draw tooltip on top of everything (if active)
        if self.tooltip_active {
            tooltip_draw(self.canvas, self.tooltip_text,
                         self.tooltip_x, self.tooltip_y,
                         self.theme.surface, self.theme.border,
                         self.theme.text, self.theme.font_size)
        }

        -- Update tweens
        self._update_tweens()

        -- Finish canvas frame (present)
        self.canvas.finish()

        self.frame_count = self.frame_count + 1
    }

    -- ============================================================
    --  Layout helpers
    -- ============================================================

    task begin_row(self, gap: num, pad: num) -> void {
        pilot avail_w = self.layout.remaining_width()
        pilot avail_h = self.layout.remaining_height()
        pilot pos = self.layout.cursor()

        -- Allocate a slot in the parent for this row (height will be determined by contents)
        -- We use a temporary height; the parent cursor will be adjusted on end_row
        self.layout.push(
            pos.x, pos.y, avail_w, avail_h,
            DIR_HORIZONTAL, gap, pad
        )
    }

    task end_row(self) -> void {
        pilot consumed = self.layout.pop()
        -- Allocate the consumed space in the parent context
        self.layout.allocate(consumed.x, consumed.y)
    }

    task begin_column(self, gap: num, pad: num) -> void {
        pilot avail_w = self.layout.remaining_width()
        pilot avail_h = self.layout.remaining_height()
        pilot pos = self.layout.cursor()

        self.layout.push(
            pos.x, pos.y, avail_w, avail_h,
            DIR_VERTICAL, gap, pad
        )
    }

    task end_column(self) -> void {
        pilot consumed = self.layout.pop()
        self.layout.allocate(consumed.x, consumed.y)
    }

    -- ============================================================
    --  Widgets
    -- ============================================================

    -- Label: display text
    task label(self, text: word) -> void {
        self.label_styled(text, LABEL_NORMAL)
    }

    task label_styled(self, text: word, style: int) -> void {
        pilot h = label_height(style, self.theme.font_size)
        pilot w = self.layout.remaining_width()
        pilot rect = self.layout.allocate(w, h)

        label_sized(self.canvas, text, rect, style,
                    self.theme.text, self.theme.text_muted, self.theme.font_size)

        self.widget_count = self.widget_count + 1
    }

    -- Button: clickable, returns true on click
    task button(self, text: word) -> bool {
        give back self.button_styled(text, BTN_NORMAL, SizeHint::auto())
    }

    task button_primary(self, text: word) -> bool {
        give back self.button_styled(text, BTN_PRIMARY, SizeHint::auto())
    }

    task button_styled(self, text: word, style: int, width_hint: SizeHint) -> bool {
        pilot btn_h = self.theme.font_size + self.theme.padding * 2
        pilot content_w = measure_text_width(text, self.theme.font_size) + self.theme.padding * 2
        pilot avail_w = self.layout.remaining_width()
        pilot btn_w = width_hint.resolve(avail_w, content_w)

        pilot rect = self.layout.allocate(btn_w, btn_h)

        -- Check interaction
        pilot result = button_check(rect, self.mouse_x, self.mouse_y,
                                    self.mouse_down, self.mouse_clicked)

        -- Draw
        button_draw(self.canvas, text, rect, style, result.hovered,
                    self.theme.surface, self.theme.accent, self.theme.accent_hover,
                    self.theme.danger, self.theme.text, self.theme.border,
                    self.theme.radius, self.theme.font_size)

        self.widget_count = self.widget_count + 1
        give back result.clicked
    }

    -- Input: text field, returns true if value changed
    task input(self, value: word, placeholder: word) -> word {
        pilot input_h = self.theme.font_size + self.theme.padding * 2
        pilot avail_w = self.layout.remaining_width()
        pilot rect = self.layout.allocate(avail_w, input_h)

        pilot my_id = self.widget_count
        self.widget_count = self.widget_count + 1

        -- Click to focus
        pilot focused = self.input_focus_id == my_id
        if self.mouse_clicked {
            if rect.contains(self.mouse_x, self.mouse_y) {
                self.input_focus_id = my_id
                self.input_cursor = value.len()
                focused = true
            } else {
                if focused {
                    self.input_focus_id = -1
                    focused = false
                }
            }
        }

        -- Handle keyboard input when focused
        pilot new_value = value
        if focused {
            -- Character input
            if self.char_typed > 0 {
                pilot ch = self.char_typed
                -- Insert character at cursor position
                pilot before = new_value.substring(0, self.input_cursor)
                pilot after = new_value.substring(self.input_cursor, new_value.len())
                -- Build new string with inserted char
                -- (Using string concatenation with the character)
                new_value = before + chr(ch) + after
                self.input_cursor = self.input_cursor + 1
            }
            -- Backspace
            if self.key_backspace and self.input_cursor > 0 {
                pilot before = new_value.substring(0, self.input_cursor - 1)
                pilot after = new_value.substring(self.input_cursor, new_value.len())
                new_value = before + after
                self.input_cursor = self.input_cursor - 1
            }
            -- Delete
            if self.key_delete and self.input_cursor < new_value.len() {
                pilot before = new_value.substring(0, self.input_cursor)
                pilot after = new_value.substring(self.input_cursor + 1, new_value.len())
                new_value = before + after
            }
            -- Cursor movement
            if self.key_left and self.input_cursor > 0 {
                self.input_cursor = self.input_cursor - 1
            }
            if self.key_right and self.input_cursor < new_value.len() {
                self.input_cursor = self.input_cursor + 1
            }
        }

        -- Draw
        input_draw(self.canvas, new_value, rect, placeholder,
                   focused, self.input_cursor,
                   self.theme.bg2, self.theme.surface, self.theme.border,
                   self.theme.accent, self.theme.text, self.theme.text_muted,
                   self.theme.font_size)

        give back new_value
    }

    -- Spacer: empty space
    task spacer(self, size: num) -> void {
        pilot dir = self.layout.current_direction()
        if dir == DIR_HORIZONTAL {
            self.layout.allocate(size, 0.0)
        } else {
            self.layout.allocate(0.0, size)
        }
    }

    task spacer_fill(self) -> void {
        pilot dir = self.layout.current_direction()
        if dir == DIR_HORIZONTAL {
            pilot remaining = self.layout.remaining_width()
            self.layout.allocate(remaining, 0.0)
        } else {
            pilot remaining = self.layout.remaining_height()
            self.layout.allocate(0.0, remaining)
        }
    }

    -- Separator: horizontal or vertical line
    task separator(self) -> void {
        pilot dir = self.layout.current_direction()
        if dir == DIR_HORIZONTAL {
            pilot rect = self.layout.allocate(1.0, self.layout.remaining_height())
            separator_draw(self.canvas, rect, self.theme.border)
        } else {
            pilot rect = self.layout.allocate(self.layout.remaining_width(), 1.0)
            separator_draw(self.canvas, rect, self.theme.border)
        }
    }

    -- Checkbox: togglable, returns true if toggled
    task checkbox(self, text: word, checked: bool) -> bool {
        pilot box_size = self.theme.font_size + 4
        pilot text_w = measure_text_width(text, self.theme.font_size)
        pilot total_w = box_size + 8 + text_w
        pilot h = box_size + 4

        pilot rect = self.layout.allocate(total_w, h)
        self.widget_count = self.widget_count + 1

        -- Check box area
        pilot box_rect = Rect {
            x: rect.x,
            y: rect.y + 2,
            w: box_size,
            h: box_size
        }

        -- Click detection
        pilot clicked = self.mouse_clicked and rect.contains(self.mouse_x, self.mouse_y)

        -- Draw box
        if checked {
            self.canvas.fill_rect(box_rect, self.theme.accent)
            -- Draw checkmark (simplified: just an X for now)
            pilot cx = box_rect.x + 4
            pilot cy = box_rect.y + 4
            self.canvas.draw_text("X", cx, cy,
                Font { size: box_size - 6, bold: true, italic: false },
                Color::rgb(255, 255, 255))
        } else {
            self.canvas.fill_rect(box_rect, self.theme.bg2)
            self.canvas.stroke_rect(box_rect, self.theme.border, 1)
        }

        -- Draw label
        pilot text_x = rect.x + box_size + 8
        pilot text_y = rect.y + (h - self.theme.font_size) / 2
        self.canvas.draw_text(text, text_x, text_y,
            Font { size: self.theme.font_size, bold: false, italic: false },
            self.theme.text)

        give back clicked
    }

    -- Slider: horizontal slider, returns true if value changed
    task slider(self, value: num, lo: num, hi: num) -> num {
        pilot slider_h = 24
        pilot avail_w = self.layout.remaining_width()
        pilot rect = self.layout.allocate(avail_w, slider_h)
        self.widget_count = self.widget_count + 1

        -- Track
        pilot track_y = rect.y + slider_h / 2 - 2
        pilot track_rect = Rect { x: rect.x, y: track_y, w: rect.w, h: 4 }
        self.canvas.fill_rect(track_rect, self.theme.bg2)

        -- Calculate thumb position
        pilot range = hi - lo
        pilot normalized = 0.0
        if range > 0.0 {
            normalized = (value - lo) / range
        }
        pilot thumb_x = rect.x + normalized * (rect.w - 16)

        -- Thumb
        pilot thumb_rect = Rect { x: thumb_x, y: rect.y + 2, w: 16, h: slider_h - 4 }
        pilot thumb_hovered = thumb_rect.contains(self.mouse_x, self.mouse_y)
        if thumb_hovered {
            self.canvas.fill_rect(thumb_rect, self.theme.accent_hover)
        } else {
            self.canvas.fill_rect(thumb_rect, self.theme.accent)
        }

        -- Fill track up to thumb
        pilot fill_rect = Rect { x: rect.x, y: track_y, w: thumb_x - rect.x + 8, h: 4 }
        self.canvas.fill_rect(fill_rect, self.theme.accent)

        -- Handle dragging
        pilot new_value = value
        if self.mouse_down and rect.contains(self.mouse_x, self.mouse_y) {
            pilot rel_x = self.mouse_x - rect.x
            pilot new_norm = rel_x / rect.w
            if new_norm < 0.0 { new_norm = 0.0 }
            if new_norm > 1.0 { new_norm = 1.0 }
            new_value = lo + new_norm * range
        }

        give back new_value
    }

    -- ============================================================
    --  Dropdown — select from a list of options
    -- ============================================================

    task dropdown(self, selected: int, items: List<word>) -> int {
        pilot dd_h = self.theme.font_size + self.theme.padding * 2
        pilot avail_w = self.layout.remaining_width()
        pilot rect = self.layout.allocate(avail_w, dd_h)

        pilot my_id = self.widget_count
        self.widget_count = self.widget_count + 1

        pilot is_open = self.dropdown_open_id == my_id
        pilot item_h = self.theme.font_size + 8
        pilot new_selected = selected

        -- Determine hover index in the list
        pilot hover_index = -1
        if is_open {
            pilot list_y = rect.y + rect.h
            if self.mouse_x >= rect.x and self.mouse_x <= rect.x + rect.w {
                if self.mouse_y >= list_y and self.mouse_y < list_y + items.len() * item_h {
                    hover_index = (self.mouse_y - list_y) / item_h
                }
            }
        }

        -- Click handling
        if self.mouse_clicked {
            if is_open {
                -- Click on an item?
                if hover_index >= 0 and hover_index < items.len() {
                    new_selected = hover_index
                }
                -- Close dropdown (whether they clicked an item or outside)
                self.dropdown_open_id = -1
            } else {
                -- Click on the dropdown button to open
                if rect.contains(self.mouse_x, self.mouse_y) {
                    self.dropdown_open_id = my_id
                }
            }
        }

        -- Draw
        dropdown_draw(self.canvas, items, new_selected, rect,
                      is_open, hover_index,
                      self.theme.surface, self.theme.bg2, self.theme.border,
                      self.theme.accent, self.theme.text, self.theme.text_muted,
                      self.theme.font_size, item_h)

        give back new_selected
    }

    -- ============================================================
    --  Tabs — tabbed content selector
    -- ============================================================

    task tabs(self, selected: int, names: List<word>) -> int {
        pilot tab_h = self.theme.font_size + self.theme.padding * 2 + 4
        pilot avail_w = self.layout.remaining_width()
        pilot rect = self.layout.allocate(avail_w, tab_h)

        self.widget_count = self.widget_count + 1

        pilot new_selected = selected
        pilot tab_w = rect.w / names.len()
        pilot hover_index = -1

        -- Check hover and click
        if self.mouse_y >= rect.y and self.mouse_y <= rect.y + rect.h {
            if self.mouse_x >= rect.x and self.mouse_x <= rect.x + rect.w {
                hover_index = (self.mouse_x - rect.x) / tab_w
                if hover_index >= names.len() { hover_index = names.len() - 1 }
                if self.mouse_clicked {
                    new_selected = hover_index
                }
            }
        }

        -- Draw
        tabs_draw(self.canvas, names, new_selected, rect, hover_index,
                  self.theme.surface, self.theme.bg, self.theme.border,
                  self.theme.accent, self.theme.text, self.theme.text_muted,
                  self.theme.font_size)

        give back new_selected
    }

    -- ============================================================
    --  Progress bar — shows completion from 0.0 to 1.0
    -- ============================================================

    task progress(self, value: num, label: word) -> void {
        pilot bar_h = self.theme.font_size + 8
        pilot avail_w = self.layout.remaining_width()
        pilot rect = self.layout.allocate(avail_w, bar_h)

        self.widget_count = self.widget_count + 1

        progress_draw(self.canvas, value, rect, label,
                      self.theme.bg2, self.theme.accent, self.theme.text,
                      self.theme.font_size)
    }

    -- ============================================================
    --  Tooltip — shows text when hovering over previous widget
    -- ============================================================

    -- Call immediately after the widget you want to attach the tooltip to.
    -- Uses the last allocated rect's position as the anchor.
    task tooltip(self, text: word) -> void {
        -- Check if mouse is near the last widget's area
        -- We use a simple heuristic: if mouse is in the current layout row
        pilot pos = self.layout.cursor()
        pilot mx = self.mouse_x
        pilot my = self.mouse_y

        -- If mouse is above the current cursor (i.e. in the area of the previous widget)
        if my < pos.y and my >= pos.y - 60 {
            self.tooltip_text = text
            self.tooltip_x = mx
            self.tooltip_y = pos.y - 4
            self.tooltip_active = true
        }
    }

    -- Explicit tooltip with anchor rect
    task tooltip_at(self, text: word, anchor: Rect) -> void {
        if anchor.contains(self.mouse_x, self.mouse_y) {
            self.tooltip_text = text
            self.tooltip_x = self.mouse_x
            self.tooltip_y = anchor.y
            self.tooltip_active = true
        }
    }

    -- ============================================================
    --  Modal — overlay dialog
    -- ============================================================

    -- Begin a modal. Returns the content rect inside the panel.
    -- Draw your modal content between begin_modal/end_modal.
    -- Pass open=true to show, false to hide.
    task begin_modal(self, open: bool, panel_w: int, panel_h: int) -> Rect {
        self.modal_open = open
        if not open {
            give back Rect { x: 0, y: 0, w: 0, h: 0 }
        }

        -- Draw overlay and panel
        pilot panel = modal_overlay_draw(
            self.canvas, self.window.width, self.window.height,
            panel_w, panel_h,
            self.theme.bg, self.theme.surface, self.theme.border
        )

        -- Push a layout context inside the panel
        self.layout.push(
            panel.x, panel.y, panel.w, panel.h,
            DIR_VERTICAL, self.theme.gap, self.theme.padding
        )

        give back panel
    }

    task end_modal(self) -> void {
        if self.modal_open {
            self.layout.pop()
        }
    }

    -- ============================================================
    --  Scroll area — scrollable region
    -- ============================================================

    -- Begin a scrollable area with a fixed visible height.
    -- Content can be taller; scrollbar appears automatically.
    -- Returns the visible content rect.
    task begin_scroll(self, visible_h: num) -> Rect {
        pilot avail_w = self.layout.remaining_width()
        pilot rect = self.layout.allocate(avail_w, visible_h)

        -- Track scroll offset for this scroll area
        pilot scroll_id = self.scroll_count
        self.scroll_count = self.scroll_count + 1

        -- Ensure we have enough scroll offset slots
        repeat until self.scroll_offsets.len() > scroll_id {
            self.scroll_offsets.push(0.0)
        }

        -- Handle mouse wheel scrolling when mouse is inside
        pilot scroll_offset = self.scroll_offsets[scroll_id]
        if rect.contains(self.mouse_x, self.mouse_y) {
            -- Use actual scroll wheel delta (positive = scroll down)
            if self.scroll_delta != 0 {
                scroll_offset = scroll_offset + self.scroll_delta * 30.0
            }
            if scroll_offset < 0.0 { scroll_offset = 0.0 }
            self.scroll_offsets[scroll_id] = scroll_offset
        }

        -- Push layout context offset by scroll position
        -- Content starts at rect.y - scroll_offset (clipped by the visible area)
        self.layout.push(
            rect.x, rect.y - scroll_offset, avail_w, 10000.0,
            DIR_VERTICAL, self.theme.gap, 0.0
        )

        -- Draw background
        self.canvas.fill_rect(rect, self.theme.bg2)

        self.widget_count = self.widget_count + 1
        give back rect
    }

    task end_scroll(self) -> void {
        pilot consumed = self.layout.pop()
        -- consumed.y is the total content height
        -- We could draw a scrollbar here based on content_h vs visible_h
        -- For now, we draw a simple indicator track
    }

    -- ============================================================
    --  Animation — smooth value interpolation
    -- ============================================================

    -- Get time since last frame in seconds
    task get_delta_time(self) -> num {
        give back self.delta_time
    }

    -- Linearly interpolate towards target by speed * delta_time.
    -- Call every frame with the current value; returns smoothed value.
    task animate(self, current: num, target: num, speed: num) -> num {
        pilot diff = target - current
        pilot step = diff * speed * self.delta_time
        -- Snap if close enough
        if diff > -0.001 and diff < 0.001 {
            give back target
        }
        give back current + step
    }

    -- Animate with easing function
    task animate_eased(self, current: num, target: num, speed: num, easing: int) -> num {
        pilot t = speed * self.delta_time
        if t > 1.0 { t = 1.0 }

        -- Apply easing to the interpolation parameter
        pilot eased_t = ease(t, easing)

        pilot diff = target - current
        if diff > -0.001 and diff < 0.001 {
            give back target
        }
        give back current + diff * eased_t
    }

    -- Register a named tween (by integer ID) with target and speed.
    -- Returns the current interpolated value.
    task tween(self, id: int, target: num, speed: num, easing: int) -> num {
        -- Find existing tween with this ID
        pilot i = 0
        repeat self.tween_count times {
            if self.tween_ids[i] == id {
                -- Update target if changed
                self.tween_targets[i] = target
                self.tween_speeds[i] = speed
                self.tween_easings[i] = easing
                give back self.tween_currents[i]
            }
            i = i + 1
        }

        -- Create new tween
        self.tween_ids.push(id)
        self.tween_currents.push(target)  -- start at target (no initial animation)
        self.tween_targets.push(target)
        self.tween_speeds.push(speed)
        self.tween_easings.push(easing)
        self.tween_count = self.tween_count + 1
        give back target
    }

    -- Trigger a tween from a starting value (one-shot)
    task tween_from(self, id: int, from: num, target: num, speed: num, easing: int) -> num {
        -- Find existing
        pilot i = 0
        repeat self.tween_count times {
            if self.tween_ids[i] == id {
                self.tween_targets[i] = target
                self.tween_speeds[i] = speed
                self.tween_easings[i] = easing
                give back self.tween_currents[i]
            }
            i = i + 1
        }

        -- Create new starting from 'from'
        self.tween_ids.push(id)
        self.tween_currents.push(from)
        self.tween_targets.push(target)
        self.tween_speeds.push(speed)
        self.tween_easings.push(easing)
        self.tween_count = self.tween_count + 1
        give back from
    }

    -- Internal: update all active tweens
    task _update_tweens(self) -> void {
        pilot i = 0
        repeat self.tween_count times {
            pilot current = self.tween_currents[i]
            pilot target = self.tween_targets[i]
            pilot speed = self.tween_speeds[i]
            pilot easing_type = self.tween_easings[i]

            pilot diff = target - current
            if diff > 0.001 or diff < -0.001 {
                pilot t = speed * self.delta_time
                if t > 1.0 { t = 1.0 }
                pilot eased_t = ease(t, easing_type)
                self.tween_currents[i] = current + diff * eased_t
            } else {
                self.tween_currents[i] = target
            }
            i = i + 1
        }
    }

    -- ============================================================
    --  Theme switching
    -- ============================================================

    task set_theme(self, new_theme: Theme) -> void {
        self.theme = new_theme
    }
}

-- ================================================================
--  Easing functions
-- ================================================================

-- Apply easing curve to a 0..1 parameter t
task ease(t: num, easing: int) -> num {
    if easing == EASE_LINEAR {
        give back t
    }
    if easing == EASE_IN {
        -- Quadratic ease in: t^2
        give back t * t
    }
    if easing == EASE_OUT {
        -- Quadratic ease out: 1 - (1-t)^2
        pilot inv = 1.0 - t
        give back 1.0 - inv * inv
    }
    if easing == EASE_IN_OUT {
        -- Cubic ease in-out
        if t < 0.5 {
            give back 4.0 * t * t * t
        }
        pilot p = 2.0 * t - 2.0
        give back 0.5 * p * p * p + 1.0
    }
    if easing == EASE_SPRING {
        -- Damped spring approximation
        -- Overshoots then settles
        pilot p = t * t
        pilot s = p * (3.0 - 2.0 * t)
        pilot overshoot = s + (s - t) * 0.3
        if overshoot > 1.0 and t > 0.8 {
            give back 1.0
        }
        give back overshoot
    }
    -- Fallback to linear
    give back t
}

-- ================================================================
--  Helpers
-- ================================================================

-- Helper: convert int to char (for text input)
-- This would normally be a runtime intrinsic
task chr(code: int) -> word {
    -- Runtime will handle the actual conversion
    give back char_to_word(code)
}
-- freak-ui Visual Test — Phase ME + MF
-- A simple but real app showing all widgets working together.
--
-- Build: build_ui_test.bat

@protagonist
task main() {
    pilot win = Window::open(WindowConfig {
        title: "FREAK UI — Visual Test",
        width: 640,
        height: 520,
        resizable: true,
        vsync: true
    })

    pilot ui = UI::new(win, Theme::alternative())

    -- State
    pilot selected_tab = 0
    pilot tab_names = ["Controls", "Animation"]

    pilot dropdown_val = 1
    pilot dropdown_items = ["Alpha", "Beta", "Gamma", "Delta"]

    pilot check_a = true
    pilot check_b = false
    pilot slider_val = 0.3
    pilot input_text = ""
    pilot progress_val = 0.0

    pilot anim_target = 0.0
    pilot anim_bar = 0.0

    pilot modal_visible = false

    repeat until ui.should_quit {
        ui.begin_frame()

        ui.label_styled("FREAK UI", LABEL_HEADING)
        ui.separator()

        selected_tab = ui.tabs(selected_tab, tab_names)
        ui.spacer(6)

        if selected_tab == 0 {
            -- Dropdown
            ui.label("Dropdown:")
            dropdown_val = ui.dropdown(dropdown_val, dropdown_items)
            ui.spacer(6)

            -- Checkboxes
            if ui.checkbox("Feature A", check_a) { check_a = not check_a }
            if ui.checkbox("Feature B", check_b) { check_b = not check_b }
            ui.spacer(6)

            -- Slider
            ui.label("Slider:")
            slider_val = ui.slider(slider_val, 0.0, 1.0)
            ui.spacer(6)

            -- Input
            ui.label("Input:")
            input_text = ui.input(input_text, "Type here...")
            ui.spacer(6)

            -- Progress bar (auto-advancing)
            progress_val = progress_val + 0.003
            if progress_val > 1.0 { progress_val = 0.0 }
            ui.progress(progress_val, "Loading...")
            ui.spacer(6)

            -- Buttons
            ui.begin_row(8, 0)
            ui.button("Normal")
            ui.button_primary("Primary")
            if ui.button_styled("Modal", BTN_DANGER, SizeHint::auto()) {
                modal_visible = true
            }
            ui.end_row()
        }

        if selected_tab == 1 {
            ui.label("Click to animate:")
            ui.spacer(4)

            ui.begin_row(8, 0)
            if ui.button("0%")   { anim_target = 0.0 }
            if ui.button("50%")  { anim_target = 0.5 }
            if ui.button("100%") { anim_target = 1.0 }
            ui.end_row()

            ui.spacer(6)
            anim_bar = ui.animate(anim_bar, anim_target, 5.0)
            ui.progress(anim_bar, "Animated")

            ui.spacer(8)
            ui.label("Easing comparison:")

            pilot v1 = ui.tween(1, anim_target, 3.0, EASE_LINEAR)
            ui.label_styled("Linear", LABEL_MONO)
            ui.progress(v1, "")

            pilot v2 = ui.tween(2, anim_target, 3.0, EASE_OUT)
            ui.label_styled("Ease Out", LABEL_MONO)
            ui.progress(v2, "")

            pilot v3 = ui.tween(3, anim_target, 3.0, EASE_SPRING)
            ui.label_styled("Spring", LABEL_MONO)
            ui.progress(v3, "")
        }

        -- Modal
        pilot mr = ui.begin_modal(modal_visible, 360, 160)
        if modal_visible {
            ui.label_styled("Dialog", LABEL_HEADING)
            ui.label("This is a modal overlay.")
            ui.spacer_fill()
            if ui.button_primary("Close") {
                modal_visible = false
            }
        }
        ui.end_modal()

        ui.end_frame()
    }

    win.close()
    say "Done."
}
